# Template for the combined NetBird server config (v0.72.x). gen-config.sh renders
# this into config.yaml, substituting __NB_DOMAIN__ (host IP:port) and fresh
# secrets. Direct mode (no reverse proxy / no TLS): everything is served on :80
# inside the container, published on host :8081, so the OIDC issuer carries the
# :8081 port and discovery resolves identically from the host and from peers.
# LOCAL DEV ONLY — production NetBird must run behind TLS (docs/04).
server:
  listenAddress: ":80"
  exposedAddress: "http://__NB_DOMAIN__"
  stunPorts:
    - 3478
  metricsPort: 9090
  healthcheckAddress: ":9000"
  logLevel: "info"
  logFile: "console"

  authSecret: "__RELAY_SECRET__"
  dataDir: "/var/lib/netbird"

  auth:
    issuer: "http://__NB_DOMAIN__/oauth2"
    signKeyRefreshEnabled: true
    dashboardRedirectURIs:
      - "http://__NB_DASHBOARD__/nb-auth"
      - "http://__NB_DASHBOARD__/nb-silent-auth"
    cliRedirectURIs:
      - "http://localhost:53000/"

  store:
    engine: "sqlite"
    encryptionKey: "__ENC_KEY__"
