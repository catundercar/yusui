# Local dev only — NEVER use these in production (docs/07 §7.3).
# Copy to deploy/.env and override. Compose has built-in defaults, so this file
# is optional for a local run.

# Postgres
POSTGRES_PASSWORD=postgres
YUSUI_MIGRATE_PASSWORD=migratesecret
YUSUI_APP_PASSWORD=appsecret
POSTGRES_HOST_PORT=5433

# Server
JWT_SECRET=dev-jwt-secret-change-me-please
CREDENTIAL_KEY=dev-credential-key-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin12345!@
SERVER_HOST_PORT=8080
LOG_LEVEL=info

# Web (the app you open in the browser)
WEB_HOST_PORT=8088
